{
  "manifest_version": 3,
  "name": "LeetGamify",
  "version": "1.0",
  "description": "sounds + overlays for LeetCode submissions",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
       "resources": [
	"sounds/*.mp3",
	"images/*.png" ],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
